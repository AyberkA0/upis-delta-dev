<body style="margin:0;padding:0;background:#0f172a;font-family:Arial,Helvetica,sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" style="padding:50px 0;">
<tr>
<td align="center">

<table width="560" cellpadding="0" cellspacing="0" style="background:#111827;border-radius:14px;padding:42px;box-shadow:0 20px 50px rgba(0,0,0,0.45);border:1px solid #1f2937;">

<tr>
<td align="center" style="font-size:28px;font-weight:700;color:#38bdf8;letter-spacing:1px;">
UPIS Delta
</td>
